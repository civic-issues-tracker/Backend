# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,example.ngrok-free.dev

# Database - PostgreSQL
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Email Settings (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your-telegram-bot-username

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Superuser defaults
SUPERUSER_EMAIL=your-superuser-email@example.com
SUPERUSER_PASSWORD=your-superuser-password
SUPERUSER_NAME=your-superuser-name
SUPERUSER_PHONE=+251900000000

# Afro Message SMS settings
AFRO_MESSAGE_API_KEY=your-afro-message-api-key
AFRO_MESSAGE_SENDER_ID=WHALE
AFRO_MESSAGE_API_URL=https://api.afromessage.com/api/send

# Redis settings (for cache and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
# REDIS_URL is optional, defaults to redis://127.0.0.1:6379/1 if not set
# REDIS_URL=redis://127.0.0.1:6379/1

# Admin creation secret (for first system admin)
ADMIN_CREATION_SECRET=your-admin-creation-secret