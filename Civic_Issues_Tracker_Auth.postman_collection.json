    {
      "name": "4. Organization Admin Management",
      "item": [
        {
          "name": "4.1 Create Organization Admin Invitation (System Admin Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Invitation created', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('invitation sent');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"orgadmin@water.com\",\n  \"organization_id\": \"YOUR_ORGANIZATION_ID_HERE\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/admin/create-org-admin/",
              "host": ["{{base_url}}"],
              "path": ["admin", "create-org-admin/"]
            }
          }
        },
        {
          "name": "4.2 Complete Organization Admin Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Registration completed', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('Registration complete');",
                  "    pm.expect(jsonData).to.have.property('access');",
                  "    pm.collectionVariables.set('access_token', jsonData.access);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"INVITATION_TOKEN_FROM_EMAIL\",\n  \"full_name\": \"Jane Organization Admin\",\n  \"password\": \"SecurePass123\",\n  \"confirm_password\": \"SecurePass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/complete-registration/",
              "host": ["{{base_url}}"],
              "path": ["complete-registration/"]
            }
