            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+251906176300\",\n  \"password\": \"TestPass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/login/",
              "host": ["{{base_url}}"],
              "path": ["login/"]
            }
